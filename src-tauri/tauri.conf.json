{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Kode",
    "version": "0.1.0",
    "identifier": "kode.com",
    "build": {
        "beforeDevCommand": "bun run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "bun run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "",
                "width": 1200,
                "height": 800,
                "decorations": false,
                "dragDropEnabled": false,
                "zoomHotkeysEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "app",
            "dmg",
            "nsis"
        ],
        "icon": [
            "icons/prod/32x32.png",
            "icons/prod/128x128.png",
            "icons/prod/128x128@2x.png",
            "icons/prod/icon.icns",
            "icons/prod/icon.ico"
        ],
        "createUpdaterArtifacts": true
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/kodestudios/kode-client/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEODA2MThCNzREQTBEMzMKUldRekRkcDBpMkdBblc0UFFRQllVdi83NEhJYnMzQmt4Mmd0ZjJ6VDFGMm1WckFoK1ZqcjZabTUK"
        }
    }
}
